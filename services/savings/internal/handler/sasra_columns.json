  "classification_thresholds": {
    "normal":       {"dpd_min": 0,   "dpd_max": 30,  "code": 1, "provision_pct": 0},
    "watch":        {"dpd_min": 31,  "dpd_max": 60,  "code": 2, "provision_pct": 5},
    "substandard":  {"dpd_min": 61,  "dpd_max": 180, "code": 3, "provision_pct": 25},
    "doubtful":     {"dpd_min": 181, "dpd_max": 360, "code": 4, "provision_pct": 50},
    "loss":         {"dpd_min": 361, "dpd_max": null, "code": 5, "provision_pct": 100}
  }
}
