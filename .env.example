# nexusSacco — local development env
# Copy to .env and adjust.

# ───────── Postgres ─────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_password
POSTGRES_DB=nexus_sacco
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://nexus:nexus_dev_password@localhost:5432/nexus_sacco?sslmode=disable

# ───────── Redis ─────────
REDIS_URL=redis://localhost:6379/0

# ───────── Identity service ─────────
IDENTITY_HTTP_ADDR=:8081
IDENTITY_LOG_LEVEL=debug
IDENTITY_ENV=development

# JWT — REPLACE in any non-dev environment. Generate with:
#   openssl rand -base64 64
JWT_SECRET=dev-only-secret-do-not-use-in-production-eef9b4c6c0f04f4d8a8b1e7f2a3b4c5d
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=nexus-identity

# Tenant / cookies
APP_DOMAIN=nexussacco.local
COOKIE_DOMAIN=.nexussacco.local
COOKIE_SECURE=false

# Web base URL template — used to build links in transactional emails.
# {slug} is replaced by the tenant slug (or "platform"). In production
# this becomes something like "https://{slug}.nexussacco.app".
WEB_BASE_URL=http://{slug}.nexussacco.local:5173

# Password reset link lifetime.
PASSWORD_RESET_TTL=30m

# Platform bootstrap — used by `make seed` to create the platform super-admin.
PLATFORM_ADMIN_EMAIL=admin@nexussacco.local
PLATFORM_ADMIN_PASSWORD=ChangeMeOnFirstLogin!1

# ───────── SMTP (MailHog in dev — no auth) ─────────
# When running the identity service on the host (make run), point at localhost.
# Inside docker-compose the service hits 'mailhog' (set automatically there).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@nexussacco.local
SMTP_FROM_NAME=nexusSacco
# MailHog inbox + JSON API live at http://localhost:8025
MAILHOG_URL=http://localhost:8025

# ───────── Accounting + posting pipeline ─────────
# Shared secret savings + member pass on X-Internal-Token when
# calling accounting's /internal/v1/post. Rotate per environment.
ACCOUNTING_INTERNAL_TOKEN=dev-internal-secret-do-not-use-in-production
ACCOUNTING_SERVICE_URL=http://localhost:8086

# /healthz on savings flips status=degraded once the oldest pending
# outbox row crosses this many seconds.
SAVINGS_HEALTHZ_OUTBOX_LAG_THRESHOLD_S=60

# Test-only escape — when "true", posting.New + accounting.New
# return a DryRun client. NEVER set in dev or production; the
# postingcheck analyzer rejects DryRun=true in non-test code.
# SAVINGS_ALLOW_NO_ACCOUNTING=true
